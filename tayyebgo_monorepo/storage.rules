rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated()
        && request.auth.uid == uid;
    }

    function getUserRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function getUserRestaurantId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.restaurantId;
    }

    function isAdmin() {
      return isAuthenticated()
        && getUserRole() == 'superAdmin';
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated()
        && getUserRole() == 'restaurantOwner'
        && getUserRestaurantId() == restaurantId;
    }

    function isCashier(restaurantId) {
      return isAuthenticated()
        && getUserRole() == 'cashier'
        && getUserRestaurantId() == restaurantId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isvalidUpload() {
      return isImage() && isUnder5MB();
    }

    // ============================================================
    // Profile pictures: user can write own, admin can write any
    // ============================================================
    match /users/{userId}/profile_picture.jpg {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isvalidUpload();
      allow delete: if isAdmin();
    }

    // ============================================================
    // Restaurant logos/menus: PUBLIC read for guest browsing
    // ============================================================
    match /restaurants/{restaurantId}/{imageName} {
      allow read: if true;
      allow write: if (isRestaurantOwner(restaurantId)
        || isCashier(restaurantId)
        || isAdmin())
        && isvalidUpload();
      allow delete: if isAdmin();
    }

    // ============================================================
    // Menu item images: PUBLIC read for guest browsing
    // ============================================================
    match /menu_items/{restaurantId}/{imageName} {
      allow read: if true;
      allow write: if (isRestaurantOwner(restaurantId)
        || isCashier(restaurantId)
        || isAdmin())
        && isvalidUpload();
      allow delete: if isAdmin();
    }

    // ============================================================
    // Driver documents: driver or admin only (NO public read)
    // ============================================================
    match /drivers/{driverId}/{documentName} {
      allow read: if isOwner(driverId) || isAdmin();
      allow write: if (isOwner(driverId) || isAdmin())
        && isvalidUpload();
      allow delete: if isAdmin();
    }

    // ============================================================
    // Generic uploads: authenticated users, own files only
    // ============================================================
    match /uploads/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isvalidUpload();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ============================================================
    // Deny everything else by default
    // ============================================================
    match /{allPaths=**} {
      allow read, write, delete: if false;
    }
  }
}
