rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated()
        && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function getUserRestaurantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId;
    }

    function isAdmin() {
      return isAuthenticated()
        && getUserRole() == 'superAdmin';
    }

    function isDriver() {
      return isAuthenticated()
        && getUserRole() == 'driver';
    }

    function isCustomer() {
      return isAuthenticated()
        && getUserRole() == 'customer';
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated()
        && getUserRole() == 'restaurantOwner'
        && getUserRestaurantId() == restaurantId;
    }

    function isCashier(restaurantId) {
      return isAuthenticated()
        && getUserRole() == 'cashier'
        && getUserRestaurantId() == restaurantId;
    }

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'email', 'phone', 'photoUrl', 'address',
                      'preferredLocale', 'fcmToken', 'updatedAt'])
        || isAdmin();
      allow delete: if isAdmin();

      // Subcollection: saved addresses
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      // Subcollection: saved addresses (user_repository.dart path)
      match /saved_addresses/{addressId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // ============================================================
    // RESTAURANTS (Vendors/Stores)
    // ============================================================
    match /restaurants/{restaurantId} {
      allow read: if isAuthenticated()
        && (resource.data.isActive == true || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin()
        || isRestaurantOwner(restaurantId);
      allow delete: if isAdmin();

      // Subcollection: menu items
      match /menu_items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin()
          || isRestaurantOwner(restaurantId)
          || isCashier(restaurantId);
      }

      // Subcollection: restaurant orders
      match /orders/{orderId} {
        allow read: if isAuthenticated()
          && (resource.data.customerId == request.auth.uid
            || resource.data.userId == request.auth.uid
            || isAdmin()
            || isRestaurantOwner(restaurantId)
            || isDriver()
            || isCashier(restaurantId));
        allow create: if isCustomer();
        allow update: if isAdmin()
          || isRestaurantOwner(restaurantId)
          || isCashier(restaurantId)
          || isDriver();
        allow delete: if isAdmin();
      }

      // Subcollection: reviews
      match /reviews/{reviewId} {
        allow read: if isAuthenticated();
        allow create: if isCustomer();
        allow update: if isOwner(request.auth.uid);
        allow delete: if isAdmin() || isOwner(request.auth.uid);
      }

      // Subcollection: promo codes
      match /promos/{promoId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin()
          || isRestaurantOwner(restaurantId);
        allow update: if isCustomer()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['usageCount', 'updatedAt']);
      }

      // Subcollection: products (admin catalog management)
      match /products/{productId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin()
          || isRestaurantOwner(restaurantId)
          || isCashier(restaurantId);
      }

      // Subcollection: categories (menu organization)
      match /categories/{categoryId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin()
          || isRestaurantOwner(restaurantId);
      }

      // Subcollection: promotions (store-level discounts)
      match /promotions/{promotionId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin()
          || isRestaurantOwner(restaurantId);
      }
    }

    // ============================================================
    // ORDERS (top-level collection)
    // ============================================================
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (resource.data.customerId == request.auth.uid
          || resource.data.userId == request.auth.uid
          || isAdmin()
          || isDriver());
      // C1 FIX: Validate customerId on create
      allow create: if isCustomer()
        && request.resource.data.customerId == request.auth.uid;
      // C2 FIX: Drivers can only update delivery-relevant fields
      allow update: if isAdmin()
        || (isDriver()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'driverId', 'driverName', 'estimatedDeliveryTime',
                        'actualDeliveryTime', 'deliveryProof', 'deliveryPin',
                        'updatedAt']))
        || isRestaurantOwner(resource.data.restaurantId)
        || isCashier(resource.data.restaurantId);
      allow delete: if isAdmin();
    }

    // ============================================================
    // MENU ITEMS (top-level collection)
    // ============================================================
    match /menu_items/{menuItemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin()
        || isRestaurantOwner(resource.data.restaurantId)
        || isCashier(resource.data.restaurantId);
    }

    // ============================================================
    // DRIVERS
    // ============================================================
    match /drivers/{driverId} {
      allow read: if isAdmin() || isOwner(driverId);
      allow write: if isAdmin() || isOwner(driverId);
    }

    // ============================================================
    // DRIVER LOCATIONS (live GPS)
    // ============================================================
    match /driver_locations/{driverId} {
      allow read: if isAdmin() || isOwner(driverId);
      allow write: if isOwner(driverId);
      allow delete: if isAdmin();
    }

    // ============================================================
    // DRIVER WALLETS (earnings/balance)
    // ============================================================
    match /driver_wallets/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow write: if isAdmin();

      // Subcollection: wallet transaction history
      match /transactions/{txnId} {
        allow read: if isOwner(driverId) || isAdmin();
        // C5 FIX: Only admin can create wallet transactions (prevents driver self-crediting)
        allow create: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ============================================================
    // DISPATCH REQUESTS (auto-dispatch matching)
    // ============================================================
    match /dispatch_requests/{requestId} {
      allow read: if isAdmin() || isDriver();
      allow create: if isAdmin();
      // C3 FIX: Drivers can only update their own dispatch requests
      allow update: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================================
    // ANYTHING REQUESTS (special delivery orders)
    // ============================================================
    match /anything_requests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin()
          || isDriver());
      allow create: if isCustomer()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin() || isDriver();
      allow delete: if isAdmin();
    }

    // ============================================================
    // DELIVERIES / DISPATCH (legacy)
    // ============================================================
    match /dispatches/{dispatchId} {
      allow read: if isAdmin() || isDriver();
      // C4 FIX: Drivers cannot delete or create dispatches
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================================
    // PAYMENTS
    // ============================================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      // C6 FIX: Only customers can create payments, and must match their own userId
      allow create: if isCustomer()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PAYMENT INTENTS (Stripe)
    // ============================================================
    match /payment_intents/{intentId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      // C7 FIX: Only customers can create payment intents, must match userId
      allow create: if isCustomer()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PAYMENT METHODS (saved cards)
    // ============================================================
    match /payment_methods/{methodId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ============================================================
    // TRANSACTIONS (ledger)
    // ============================================================
    match /transactions/{txnId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow write: if isAdmin();
    }

    // ============================================================
    // LOYALTY TRANSACTIONS
    // ============================================================
    match /loyalty_transactions/{txnId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PAYOUTS (driver/restaurant settlements)
    // ============================================================
    match /payouts/{payoutId} {
      allow read: if isAdmin()
        || isRestaurantOwner(resource.data.restaurantId)
        || isOwner(resource.data.driverId);
      allow write: if isAdmin();
    }

    // ============================================================
    // SETTLEMENTS
    // ============================================================
    match /settlements/{settlementId} {
      allow read: if isAdmin()
        || isRestaurantOwner(resource.data.restaurantId);
      allow write: if isAdmin();
    }

    // ============================================================
    // PROMOTIONS / PROMOS
    // ============================================================
    match /promos/{promoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isCustomer()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usageCount', 'updatedAt']);
    }

    // ============================================================
    // NOTIFICATIONS
    // ============================================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.recipientId);
      allow delete: if isAdmin();
    }

    // ============================================================
    // ACTIVITY LOG (admin audit trail)
    // ============================================================
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // CONFIG (app-wide settings)
    // ============================================================
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // SETTINGS (legacy, same as config)
    // ============================================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // CUSTOMERS (denormalized customer data)
    // ============================================================
    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      // H1 FIX: Customers can only update safe fields (no loyaltyPoints, walletBalance, etc.)
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'email', 'phone', 'profileImage', 'addresses',
                      'notificationPreferences', 'updatedAt'])
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // BRANDS (multi-tenant top-level)
    // ============================================================
    match /brands/{brandId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // BRANCHES (physical locations)
    // ============================================================
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // ZONES (dispatch zones)
    // ============================================================
    match /zones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // APPROVALS (admin workflow)
    // ============================================================
    match /approvals/{approvalId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================================
    // DOCUMENTS (driver/store document verification)
    // ============================================================
    match /documents/{documentId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ============================================================
    // DRIVER ASSIGNMENTS (admin auto-dispatch records)
    // ============================================================
    match /driverAssignments/{assignmentId} {
      allow read: if isAdmin() || isDriver();
      allow write: if isAdmin();
    }

    // ============================================================
    // SUBSCRIPTIONS (store subscription plans)
    // ============================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================================
    // CONTRACTS (driver/restaurant agreements)
    // ============================================================
    match /contracts/{contractId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    // ============================================================
    // COUPONS (discount codes)
    // ============================================================
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // CAMPAIGNS (marketing)
    // ============================================================
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // REPORTS (generated analytics)
    // ============================================================
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================================
    // FEATURE FLAGS
    // ============================================================
    match /feature_flags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // SUPPORT TICKETS
    // ============================================================
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      // H3 FIX: Validate userId on create
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ============================================================
    // SUPPORT (docs/knowledge base)
    // ============================================================
    match /support/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // MARKETING (content)
    // ============================================================
    match /marketing/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // EMERGENCY ALERTS (driver SOS)
    // ============================================================
    match /emergency_alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isDriver();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // PROMO USAGE (server-side tracking)
    // ============================================================
    match /promo_usage/{usageId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isCustomer();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // FRAUD SCORES (server-side computation)
    // ============================================================
    match /fraud_scores/{scoreId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // ORDER FLAGS (server-side fraud detection)
    // ============================================================
    match /order_flags/{flagId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // USER DEVICES (device fingerprinting)
    // ============================================================
    match /user_devices/{deviceId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // DISPUTES (order disputes)
    // ============================================================
    match /disputes/{disputeId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // WALLET TRANSACTIONS (top-level, used by customer wallet screen)
    // ============================================================
    match /wallet_transactions/{txnId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // SOS ALERTS (driver emergency alerts)
    // ============================================================
    match /sos_alerts/{alertId} {
      allow read: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // DRIVER REPORTS (safety/incident reports)
    // ============================================================
    match /driver_reports/{reportId} {
      allow read: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver()
        && request.resource.data.driverId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // SEARCH HISTORY (user search queries)
    // ============================================================
    match /search_history/{historyId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // CONTRACT REQUESTS (partner contract submissions)
    // ============================================================
    match /contract_requests/{requestId} {
      allow read: if isAdmin()
        || (isRestaurantOwner(resource.data.restaurantId));
      allow create: if isRestaurantOwner(request.resource.data.restaurantId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // REVIEWS (top-level, used by review_service.dart)
    // ============================================================
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isCustomer()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (isOwner(resource.data.userId));
      allow delete: if isAdmin()
        || isOwner(resource.data.userId);
    }

    // ============================================================
    // DENY everything else by default
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
