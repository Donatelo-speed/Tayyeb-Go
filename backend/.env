# OmniMarket Backend Configuration

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=omnimarket
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT Secret (change in production!)
JWT_SECRET=omni_market_super_secret_key_2024_change_this

# Cloudinary (for image hosting - get from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret